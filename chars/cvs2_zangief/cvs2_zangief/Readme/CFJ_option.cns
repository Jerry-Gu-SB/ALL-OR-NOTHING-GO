;^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
[Statedef 9999]
ctrl = 0
anim = 8050
velset = 0,0

;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~EX Groove~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
;選択数の上限はありませんが、４０００ポイントを越えると、越えた分に応じて防御力が下がります。また、２０００ポイント未満の場合攻撃力がポイント数に応じて攻撃力・防御力が上がります。
;if you select over 4000 points, this char's defence is down.And if you select 2000 less points, this char's attack and defence is up.

;=====================ゲージセレクト(Gauge Select)

;ゲージ（０：Ｃゲージ(1800P)、１：Ａゲージ(2200P)、２：Ｐゲージ(800P)、３：Ｓゲージ(1600P)、４：Ｎゲージ(1200P)、５：Ｋゲージ(1000P)、６：ゲージなし(0P)）
;Gauge(0:C-Gauge(1800P), 1:A-Gauge(2200P), 2:P-Gauge(800P), 3:S-Gauge(1600P), 4:N-Gauge(1200P), 5:K-Gauge(1000P),6:None(0P))
[state 9999,varset]
type = parentvarset
trigger1 = time=0
fvar(12) = 2

;=====================システムセレクト(System Select)

;システム1（０：なし(0P)、１：ブロッキング(1600P)、２：ジャストディフェンス(1400P)、３：両方(3000P)）
;System1(0:None(0P), 1:Parry(1600P), 2:Just Defence(1400P), 3:Both(3000P))
[state 9999,varset]
type = varset
trigger1 = time=0
fvar(13) = 0

;システム2（０：なし(0P)、１：チェーンコンボ(800P)、２：空中チェーンコンボ(700P)、３：両方(1500P)）
;System2(0:None(0P), 1:Chain Combo(800P), 2:Air Chain Combo(700P), 3:Both Chain Combo and Air Chain Combo(1500P)) 
[state 9999,varset]
type = varset
trigger1 = time=0
fvar(14) = 0

;システム3（０：なし(0P)、１：スーパーコンボキャンセル(1000P)、２：キャンセルエニィムーブ(1000P)、３：両方(2000P)）
;System3(0:None(0P), 1:Super Aurts cancelling(1000P), 2:cancelling Any Move(1000P), 3:Both(2000P)) 
[state 9999,varset]
type = varset
trigger1 = time=0
fvar(15) = 0
