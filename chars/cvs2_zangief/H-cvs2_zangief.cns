;ファイナルアトミックバスター(Final Atmic Buster)
[Statedef 3050]
type= S
movetype = A
physics = S
ctrl = 0
velset = 0,0
juggle = 15
anim = 3000+(var(49)=5)*5

[State 420,PlaySnd]
type = PlaySnd
trigger1 = time=4
value = ifelse(var(1),1400,3000), 0
channel = 1

[State 3500, AfterImage]
type = AfterImage
trigger1 = time=4 && !var(56)
time = 999
length = 10
TimeGap  = 3
FrameGap = 4
palbright = 1,1,1
palContrast = ifelse(var(2)=1,50,ifelse(var(1)=1,50,ifelse(Var(1)=2,150,128))), ifelse(var(2)=1,50,ifelse(!var(1),128,50)), ifelse(var(2)=1,150,ifelse(var(1)=1,150,ifelse(Var(1)=2,50,128)))
PalMul = .5,.5,.5
trans = add1

[State 4500, AfterImage]
type = AfterImage
trigger1 = Time=4 && var(56)
time = 999
length = 10
TimeGap  = 3
FrameGap = 4
palbright = 1,1,1
palContrast = 0, 100, 150
palmul = .5,.5,.5
trans = add1

[State 3500,NotHitby]
type = Varset
trigger1 = Time=0
fvar(11)=random%2

[State 3500,NotHitby]
type = NotHitBy
trigger1 = Time=0
value = SCA
time = ifelse(var(1)=1,61,ifelse(var(1)=2,68,56))

[State -2, mask]
type = Helper
trigger1 = !NumHelper(7500) && Time=2
helpertype = normal
name = "super_effect"
id = 7500
facing = 1
pos = 12,-95
postype = P1
stateno = 7500+(var(59)=[3,5])*10
keyctrl = 0
pausemovetime = 9999
supermovetime = 9999
ownpal = 1
ignorehitpause = 1

[State 3500,NotHitby]
type = Varset
trigger1 = Time=0
var(2) = 0

[State 3500,NotHitby]
type = Varset
trigger1 = Time=3 && P2stateno=40
var(2) = 1

[State 3000, Pause]
type = Pause
trigger1 = time=3
time = 50
movetime = 50

[State 800, 1]
type = HitDef
triggerall = P2MoveType!=H && !var(56)
triggerall = P2StateNo!=[150,155]
triggerall = !var(2)
triggerall = AnimElem = 2
trigger1 = P2bodydist X<=82 && !var(49)
trigger2 = P2dist X<=122 && var(49)=1
trigger3 = P2dist X<=116 && var(49)=2
trigger4 = P2bodydist X<=76 && var(49)=3
trigger5 = P2bodydist X<=65 && var(49)=4
trigger6 = P2bodydist X<=52 && var(49)=5
trigger7 = P2bodydist X<=76 && var(49)=6
attr = S, ST
hitflag = M-
priority = 7, Dodge
sparkno = -1
p1facing = 1
p2facing = 1
p1stateno = 3051+var(1)*10
p2stateno = 3056+var(1)*10
guard.dist = 0
numhits = 0
getpower = 0*var(5)

[State 800, 1]
type = HitDef
triggerall = var(56)
triggerall = P2StateNo!=[150,155]
triggerall = !var(2)
triggerall = AnimElem = 2
trigger1 = P2bodydist X<=82 && !var(49)
trigger2 = P2dist X<=122 && var(49)=1
trigger3 = P2dist X<=116 && var(49)=2
trigger4 = P2bodydist X<=76 && var(49)=3
trigger5 = P2bodydist X<=65 && var(49)=4
trigger6 = P2bodydist X<=52 && var(49)=5
trigger7 = P2bodydist X<=76 && var(49)=6
attr = S, ST
hitflag = M
priority = 7, Dodge
sparkno = -1
p1facing = 1
p2facing = 1
p1stateno = 3051+var(1)*10
p2stateno = 3056+var(1)*10
guard.dist = 0
numhits = 0
getpower = 0*var(5)

[state 1350]
type = AttackDist
trigger1 = 1
value = 0

[state 1350]
type = StatetypeSet
trigger1 = AnimElem=3
movetype = I

[state 1350]
type = PlaySND
trigger1 = AnimElem=5
value = 800,2
channel = 1

[State 3500,Exit]
type =ChangeState
trigger1 = AnimTime=0
value = 0
ctrl=1

