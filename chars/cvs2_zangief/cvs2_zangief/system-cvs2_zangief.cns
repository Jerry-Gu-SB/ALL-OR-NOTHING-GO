value = ifelse(!fvar(31)&&command="ax"&&((!fvar(37)&&var(59)!=2&&var(59)!=5)||(fvar(37)&&(ceil(fvar(14))%32>15||ceil(fvar(14))%64>31))),ifelse((!fvar(37) && var(59)=3)||(fvar(37) && ceil(fvar(14))%64>31),910,900),ifelse(command="holdback",120,0))
ctrl = ifelse(!fvar(31)&&command="ax"&&((!fvar(37)&&var(59)!=2&&var(59)!=5)||(fvar(37)&&(ceil(fvar(14))%32>15||ceil(fvar(14))%64>31))),0,1)

[State 52, 4]
