;イントロ
[Statedef 190]
type = S
movetype = I
velset = 0,0
ctrl = 0
anim = 190

[State 190,Exit]
type = ChangeState
trigger1 = Time = 0 && ((enemy,name="raiden"&&enemy,authorname="H”")||P2name="cvsraiden"||P4name="cvsraiden")
value = 191

[State 190,Exit]
type = ChangeState
trigger1 = Time = 0 && (enemy,name="CvS2Eagle"||P2name="cvseagle"||P4name="cvseagle")
value = 192

[State 190,Snd]
type = PlaySnd
trigger1 = time=1
value = 190,0
channel = 1

[State 190,Snd]
type = PlaySnd
trigger1 = AnimElem=10
value = 190,1

[State 190,1]
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 190,Exit]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

;VSライデン(Raiden)
[statedef 191]
type = S
physics = S
ctrl = 0
velset = 0,0
anim = 191

[state 191]
type = ScreenBound
trigger1 = 1
value = 0

[state 191]
type = VarSet
trigger1 = time=0
var(1) = ceil(Pos X)

[state 191]
type = PosSet
trigger1 = time=0
x = -25*ifelse(facing=-1,-1,1)

[state 191]
type = PlaySND
trigger1 = AnimElem=17
value = 191,0
channel = 1

[state 191]
type = StatetypeSet
trigger1 = AnimElem=24
statetype=A
physics = N

[state 191]
type = VelSet
trigger1 = AnimElem=24,=1
x = -Abs(Pos X-var(1))*0.0300
y = -7.5

[state 191]
type = VelAdd
trigger1 = AnimElem=24,>1
y = .45

[state 191]
type = ChangeAnim
trigger1 = Vel Y>0 && Pos y>=0
value = 192

[state 191]
type = PlaySND
trigger1 = Vel Y>0 && Pos y>=0
value = 100,2

[state 191]
type = StatetypeSet
trigger1 = Vel Y>0 && Pos y>=0
statetype=S
physics = S

[state 191]
type = PosSet
trigger1 = Vel Y>0 && Pos y>=0
x = var(1)
y = 0

[state 191]
type = VelSet
trigger1 = Vel Y>0 && Pos y>=0
x = 0
y = 0

[State 190,Exit]
type = ChangeState
trigger1 = Anim=192&&AnimTime = 0
value = 0

