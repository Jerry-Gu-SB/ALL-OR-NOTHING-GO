;ジャンプ予備動作
[Statedef 40]
type = S
movetype=H
physics = S
anim = 40+(((var(59) = 2 || var(59) = 3 || var(59) = 4 || var(59) = 5)&&!fvar(37))||(fvar(37) && ceil(fvar(14))%4096>2047))*10
ctrl=0
velset = 0,0

[State 52, 3]
type = ChangeAnim
trigger1 = prevstateno=52 && time=1
value = 40+(((var(59) = 2 || var(59) = 3 || var(59) = 4 || var(59) = 5)&&!fvar(37))||(fvar(37) && ceil(fvar(14))%4096>2047))*10

[State 100, Helper]
type = Helper
trigger1 = Animtime=0
id = 7920
stateno=7920
pos = 0,0
postype = p1
ownpal = 1
ignorehitpause = 1

;|||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||
;CPU用

[State 40,1]
type = VarSet
triggerall = PrevStateNo != 100 && PrevStateNo != 101
triggerall = fvar(38) && Time = 0
trigger1 = enemynear,Statetype=A && P2BodyDist X <80 && enemynear,Pos Y <-55
trigger2 = (P2BodyDist X =[0,60]) && enemynear,Statetype!=A
trigger2 = (random = [0,350]) && var(59)<=1
trigger3 = (random = [0,400]) && enemy,numproj>0
trigger3 = P2BodyDist X>100 && !(enemynear,Statetype=A && enemynear,Pos Y <-50)
trigger4 = enemynear,backedgebodydist <=60 && var(56)
trigger5 = (P2bodydist X=[80,100]) && random%5<=3
sysvar(1) = 0

[State 40,2]
type = VarSet
triggerall = PrevStateNo != 100 && PrevStateNo != 101
triggerall = fvar(38) && Time = 0 && !var(56)
trigger1 = ((random = [400,1000]) && enemy,numproj>0) &&  P2BodyDist X>100
trigger2 = enemynear,Statetype=A && P2BodyDist X >=80 && enemynear,Pos Y <-55
trigger3 = P2bodydist X<60 && enemynear,BackEdgeBodyDist <=0
trigger4 = (P2bodydist X=[40,60+(var(54)%3=0)*60]) && (var(59)=2 || var(59)=3 || var(59)=4 || var(59)=5)
trigger5 = enemy,numproj=0 && P2bodydist X>80
trigger6 = P2bodydist X<60 && random%3!=0
sysvar(1) = 1

;||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||
;Player
[State 40,SysVarSet]
type = Varset
trigger1 = Time=0 && !fvar(38)
sysvar(1) = command="holdfwd"-command="holdback"

;小・大ジャンプ用
[State 40,VarSet]
type = VarSet
trigger1 = Time=0
var(7)=0

;小・大ジャンプ用
[State 40,VarAdd]
type = VarAdd
triggerall = !fvar(38)
trigger1 = AnimTime=0 && var(7)!=2
trigger1 = command!="holdup" && (((var(59) = 2 || var(59) = 3 || var(59) = 4 || var(59) = 5)&&!fvar(37))||(fvar(37) && ceil(fvar(14))%4096>2047))
trigger2 = ((command="longjump" && fvar(2)<8) || PrevStateNo=100) && Time=0
var(7)=1+((command="longjump" && fvar(2)<8) || PrevStateNo=100)

;小ジャンプ用
[State 40,VarAdd]
type = Varset
triggerall = fvar(38) && (P2BodyDist X=[0,60+(var(54)%3!=0)*60]) && (((var(59) = 2 || var(59) = 3 || var(59) = 4 || var(59) = 5)&&!fvar(37))||(fvar(37) && ceil(fvar(14))%4096>2047)) && P2statetype!=A
trigger1 = Time=0
var(7)=1

;大ジャンプ用
[State 40,VarAdd]
type = Varset
triggerall = fvar(38) && (P2BodyDist X>=ifelse(var(59)<2,140,160)||(enemy,numproj>0&&sysvar(1)=0))
trigger1 = Time=0
var(7)=2

[State 40,PlaySnd]
type = PlaySnd
trigger1 = animtime=0 && var(7)<2
value = 40,0

[State 40,PlaySnd]
type = PlaySnd
trigger1 = animtime=0 && var(7)>=2
value = 40,1

[State 40,VelSet]
type = VelSet
trigger1 = AnimTime=0 && var(7)<2
x = ifelse(sysvar(1)=1,const(velocity.jump.fwd.x),ifelse(sysvar(1)=-1,const(velocity.jump.back.x),0))
y = (const(velocity.jump.y)-(var(49)=2)*.25+.25*(sysvar(1)=1)-.13*(sysvar(1)=-1))*ifelse(var(7),.8,1)

[State 40,VelSet]
type = VelSet
trigger1 = AnimTime=0 && var(7)>=2
x = ifelse(sysvar(1)=1,const(velocity.runjump.fwd.x),ifelse(sysvar(1)=-1,const(velocity.runjump.back.x),0))
y = (const(velocity.jump.y)+.25*(sysvar(1)=1)-.13*(sysvar(1)=-1))*ifelse(sysvar(1)=0,1.15,1.045)

[State 40,ChangeState]
type = ChangeState
trigger1 = AnimTime=0
value = 50
ctrl = 1

