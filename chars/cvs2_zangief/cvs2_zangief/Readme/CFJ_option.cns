;~~~~~~~~~~~~~~~~~~~~~
;エフェクト表示設定(Change Effect)
[State -1]
type = parentVarset
trigger1 = time=0
fvar(0)=0
;(0 OR 1 OR 2(0:PS2版, 1：スーパーコンボ（超必殺技）発動エフェクトが小さい, 2:FINISH時のエフェクトを非表示, 3:1と2の両方))
;(0 OR 1 OR 2(0:PS2, 1:Effect of Super Aurts is smaller, 2:Effect is invinsible in finish, 3:1and2))

;一部の画像の変更(change to some pictures)
[State -1]
type = parentVarset
trigger1 = time=0
fvar(35)=1
;(0 OR 1(0:原作どおり,1：腕が多少細くなる))
;(0:OFF 2:ON)


;キャンセル受付時間
[State -1]
type = parentVarset
trigger1 = time=0
fvar(21)=0;←(0 OR 1(0:原作どおり,1：キャンセル受付時間が長くなる（原作とは違う）))


;グルーヴ別調整(some groove is weakened or stronged)
[state 30000,varset]
type = parentvarset
trigger1 = time=0
fvar(22) = 1
;(0:なし、1:あり)
;(0:OFF, 1:ON)

;Ａグルーヴの調整（ガード時の削りダメージは２０回まで（それ以降は０）、オリジナルコンボ中に攻撃を食らうとゲージが0に）
;A-Groove(When you're guarded 21 times or more, guarded damage is 0. When you're damaged using cutom combo, gauge is 0.)

;Ｐグルーヴの調整（ブロッキング成功時のゲージ増加量が５ポイントから８ポイント及びガードクラッシュゲージ2ドット回復）
;P-Groove(Blocking Bonus:increasing gauge 8 point(old 5 point) and guard clash gauge 2 dot.)

;Ｓグルーヴの調整（避け終了後5Fの間は避けが使用できない、ゲージ溜め速度アップ、MAX時のLv.1超必殺技の威力1.3倍に）
;S-Groove(If you use dodge, you can't use dodge while 5F. Power Charge is increased. When gauge is maximum, Lv.1 super combo is increasing damage(1.3(old1.0)).)

;Ｋグルーヴの調整（食らったときのゲージ増加量を『ダメージ/100+2』→『ダメージ/100』に、怒り中の防御力増加なし、ジャストディフェンス成功時にガードクラッシュゲージ1ドット回復）
;K-Groove(Amount of increasing gauge is decreased(damage/100(old:damage/100+2)). Increasing defence is nothing while gauge is maximum. Just Defence Bonus:increasing guard clash gauge 1 dot.)

;======================
;ガードクラッシュゲージ位置調整(Adjustment position of Guard Clash Gauge)
;X座標
[state 30000,varset]
type = varset
trigger1 = time=0
fvar(9) = 0;(0:デフォルト、+：前、-：後)

;Y座標
[state 30000,varset]
type = varset
trigger1 = time=0
fvar(10) = 0;(0:デフォルト、+：上、-：下)

;~~~~~~気絶・ガードクラッシュON/OFF(Dizzy/Guard Clash Gauge ON/OFF)
;気絶(Dizzy)
[state 30000,varset]
type = varset
trigger1 = time=0&&root,roundsexisted<=0
fvar(30) = 0;(0:デフォルト、0：あり、1：なし)(0:ON(Default), 1:OFF)

;ガードクラッシュ(Guard Clash)
[state 30000,varset]
type = varset
trigger1 = time=0&&root,roundsexisted<=0
fvar(31) = 0;(0:デフォルト、0：あり、1：なし)(0:ON(Default), 1:OFF)

[state 9999]
type = changestate
trigger1 = time=0
value = 9998
