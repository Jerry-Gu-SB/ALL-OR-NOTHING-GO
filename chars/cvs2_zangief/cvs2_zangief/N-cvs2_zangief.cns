fvar(29) = (ifelse((stateno%100=[50,59])||(stateno%100=[20,29]),17,ifelse((stateno%100=[40,49])||(stateno%100=[10,19]),14,10))+4)*ifelse(!numtarget||moveguarded,-1,1)

