[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
