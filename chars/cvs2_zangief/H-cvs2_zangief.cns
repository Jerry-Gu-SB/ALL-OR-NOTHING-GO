;lv.1ファイナルアトミックバスター(lv.1 Final Atmic Buster)
[Statedef 3000]
type = S
movetype = A
physics = S
poweradd = -1000+(!var(22)&&var(59)=3 && (100*Life/const(data.life))<=30)*1000-(var(59)=1&&!var(21))*500
ctrl = 0
velset = 0,0

[State 3000]
type = varset
trigger1 = time=0
var(2)=0

[State 3000]
type = varset
trigger1 = (prevstateno=3050||prevstateno=3150) && time=0
var(2)=1

[State 1000, VarSet]
type = VarSet
trigger1 = Time=0
var(1)=0

[State 3000]
type = varset
trigger1 = (prevstateno=[1000,2099]) && time=0 && !var(21)
trigger2 = (prevstateno=[3000,3999]) && time=0 && !var(21)
var(19)=1

[State 1000,2]
type = ChangeState
trigger1 = Time=0
value = 3050

