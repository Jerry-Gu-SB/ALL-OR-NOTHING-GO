;Var(0):
;Var(1):強弱判定など
;Var(2):方向判定など
;Var(3):キャンセル可能・不可能判定 1:必殺技 2:超必殺技 3:空振り 4:オリコン 5:Lv.2
;Var(4):KO時やられ声
;Var(5):グルーヴ別ゲージ増加量
;Var(6):グルーヴ別ゲージ増加量（相手用）
;Var(7):小・大ジャンプ判定
;Var(8):
;var(9):２ヒットの通常技判別１(ガードクラッシュ用)
;var(10):２ヒットの通常技判別２(ガードクラッシュ用)
;var(11):GetHitvar(CtrlTime)
;var(12):体力減少判別
;var(13):ヒット・ガード中判定
;var(14):カウンターヒット判定
;var(15):
;Var(16):ヒット数（コンボ補正用）
;var(17):削りＫＯ判定
;var(18):空中コンボ制限数
;var(19):LV２キャンセル判定
;Var(20):gethitvar(damage)
;var(21):オリコン中判定
;var(22):SグルＭＡＸ・パワーＭＡＸ・怒りゲージ発動中判定
;var(23):SグルＭＡＸ・パワーＭＡＸ・怒りゲージ発動残り時間
;Var(24):Reversal用コマンド受付
;var(25):投げ抜け可能状態判定
;Var(26):FirstAttack判別
;var(27):Reversal判別
;var(28):Nグルーヴゲージ残量（PowerMAX用）など
;var(29):気絶値残量
;var(30):気絶中判定
;var(31):ガードクラッシュゲージ残量
;var(32):ガードクラッシュ中判定
;var(33):ガードクラッシュ時間
;var(34):ブロッキング（前）入力
;var(35):ブロッキング（下）入力
;var(36):ブロッキング（前）受付時間
;var(37):ブロッキング（下）受付時間
;var(38):Life
;var(39):画面暗転前ガードしているかどうか（強制停止時間中ガード不可）
;var(40):カウンターヒットエフェクト表示位置x軸
;var(41):カウンターヒットエフェクト表示位置y軸
;var(42):
;Var(43):
;Var(44):
;Var(45):
;Var(46):
;Var(47):気絶値（相手）
;Var(48):気絶残り時間（相手用）
;var(49):性能変化(0:CVS2, 1:CVS1, 2:CFJ, 3:ZERO3(Alpha3), 4:ZERO2(Alpha2), 5:SSFIIX 6:SFIV, 7:EX-mode)
;var(50):ジャストディフェンス成功判別
;var(51):ジャストディフェンス入力
;var(52):メッセージアイコン１、２段目有無
;var(53):
;var(54):ランダム（CPUの動き）
;var(55):ジャンプ・回り込み・避け中に食らったか
;var(56):オリコン残り時間
;var(57):怒りゲージ
;Var(58):ヒット数メッセージ用
;var(59):グルーヴ判別
;fvar(0):エフェクトの変更
;fVar(1):
;fVar(2):大ジャンプコマンド用
;fVar(3):攻撃力補正（自分・相手体力）
;fvar(4):グルーヴ別攻撃力補正
;fvar(5):
;fvar(6):コンボ数によるダメージ補正
;fvar(7):補正後の攻撃力
;fvar(8):ガードされた数
;fvar(9):ガードクラッシュゲージの位置
;fvar(10):スーパーコンボ・超必殺技飛び道具空中ガード
;fvar(11):暗転後の強制停止時間・ダウン回避可能技判別
;fvar(12)~fvar(14):EX-Groove Select
;fvar(15):
;fvar(16):ガードクラッシュ時間（相手側）
;fvar(17):ファイネストＫＯ判別
;fvar(18):最大コンボ数記憶用
;fvar(19):相手に与えたダメージ
;fvar(20):ガードクラッシュ・気絶処理ON/OFF設定
;fvar(21):キャンセル受付時間
;fvar(22):グルーヴ別オリジナル調整
;fvar(23):ガードクラッシュゲージ残量（相手側）
;fvar(24):ガードクラッシュ中判定（相手側）
;fvar(25):気絶耐久値増加用(自分・相手兼用)
;fvar(26):EX-Grooveポイント
;fvar(27):画像の変更
;fvar(28):
;fvar(29):ヒット・ガード時間判別
;fvar(30):状態判定用時間
;fvar(31):避け中判定(option)
;fvar(32):相手の隙判別・小ジャンプ中（相手）判定
;fvar(33):状態判定
;fvar(34):相手のリーチ判別
;fvar(35):ガードすべき状況判別
;fvar(36):跳び込みヒット判定
;fvar(37):EX-Groove判別
;fvar(38):AI判定
;fvar(39):システム判別(1:CVS2, 2:SF3)
;---------------------------------------------------------------------

;---------------------------------------------------------------------
; 基本設定
[Data]
life = 1084           ; 体力ゲージ、上限値（デフォルト：1000）
power = 3000	   ; パワーゲージ、デフォルト：1000
attack = 100         ; 攻撃力（％）
defence = 100        ; 防御力（％）
fall.defence_up = 50 ; 空中コンボ修正率（％）
liedown.time = 16    ; ダウン時間
airjuggle = 15       ; 空中コンボ
sparkno = 0          ; 初期ヒットスパーク番号
guard.sparkno = 40   ; 初期ガードスパーク番号
KO.echo = 0          ; ＫＯボイスエコー（0:OFF、1:ON）
volume = 50          ; キャラボイスボリューム値
IntPersistIndex = 49 ;次のラウンドに持ち越すVarを決める
FloatPersistIndex = 20;次のラウンドに持ち越すfVarを決める

[Size]
xscale = 1         ; 水平サイズ倍率
yscale = 1           ; 垂直サイズ倍率
ground.back = 24     ; キャラ幅（地上、後ろ側）
ground.front = 24    ; キャラ幅（地上、前側）
air.back = 16        ; キャラ幅（空中、後ろ側）
air.front = 16       ; キャラ幅（空中、前側）
z.width = 10         ; キャラ幅（ｚ軸）
height = 60	     ; キャラの高さ（ジャンプで飛び越せる高さ）
attack.width = 4,4   ;Default attack width: back, front
attack.dist = 320    ;Default attack distance
proj.attack.dist = 320;Default attack distance for projectiles
proj.doscale = 0     ;Set to 1 to scale projectiles too   
head.pos = 4,-100     ; 頭部座標
mid.pos = -14,-67    ; 体中心部座標
shadowoffset = 0     ; キャラの影・オフセット値

[Velocity]
walk.fwd  = 3.1275      ; 前進速度
walk.back = -1.875     ; 後退速度
run.fwd  = 4.48, 0    ; 前ダッシュ速度（y<0の場合、ホップステップ）
run.back = -4.72,-6.65   ; バックステップ速度（y=0の場合、走り）
jump.neu = 0,-9.0     ; 垂直ジャンプ速度
jump.fwd = 2.3      ; 前方ジャンプ速度
jump.back = -2.525    ; 後方ジャンプ速度
runjump.fwd = 4.35      ; 前方ジャンプ速度（ダッシュ中）
runjump.back = -4.20 ; 後方ジャンプ速度（ダッシュ中）
;airjump.neu = 0,-9.3      ; 空中垂直ジャンプ速度
;airjump.back = -2.55,-8.1 ; 空中後方ジャンプ速度
;airjump.fwd = 2.5,-8.1    ; 空中前方ジャンプ速度

[Movement]
airjump.num = 0       ; 空中ジャンプ回数
;airjump.height = 35  ; 空中ジャンプ最低高度
yaccel = .507          ; キャラ重力加速度
stand.friction = .85  ; 摩擦係数（立ち状態）
crouch.friction = .82 ; 摩擦係数（しゃがみ状態）

