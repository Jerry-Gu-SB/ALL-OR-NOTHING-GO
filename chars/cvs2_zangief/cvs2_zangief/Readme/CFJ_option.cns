;サブシステム3（０：なし(0P)、１：ガードキャンセル攻撃(400P)、２：ガードキャンセル移動(300P)、３：両方(700P)）
;Sub System3(0:None(0P), 1:Counter Attack(400P), 2:Counter Movement(300P), 3:Both(700P))
[state 9999,varset]
type = varset
trigger1 = time=0
fvar(18) = 0

;サブシステム4（０：なし(0P)、１：空中ガード(500P)、２：小ジャンプ(600P)、３：両方(1100)）
;Sub System4(0:None(0P), 1:Air Guard(500P), 2:Small Jump(600P), 3:Both(1100P))
[state 9999,varset]
type = varset
trigger1 = time=0
fvar(19) = 0

;サブシステム5（０：なし(0P)、１：時間差起き上がり(200P)、２：ダウン回避(300P)、３：両方(500P)）
;Sub System5(0:None(0P), 1:Tactical Recovery(200P), 2:Safe Fall(300P), 3:Both(500P))
