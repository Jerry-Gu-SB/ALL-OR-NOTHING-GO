;_/_/_/_/CPU_/_/_/_/
;---------------------------------------------------------------------------
;立ち状態(ＣＰＵ)
[Statedef 3]
type    = S
physics = S
anim = 0+(fvar(27)>0)
sprpriority = 0
velset = 0,0
ctrl =0

[State 13, 1]
type =Turn
trigger1 = P2Dist X<0

[State 13, 1]
type = ChangeState
trigger1 = roundstate!=2
value = 0
ctrl = 1

[State 13, 1]
type = ChangeState
trigger1 = ((AnimElemTime(1) = [10,16]) && random <100) || ((AnimElemTime(1) = [66,70]) && random <50) || AnimElemTime(1) = 108
value = 0
ctrl = 1

;---------------------------------------------------------------------------
;しゃがみ状態(ＣＰＵ)
[Statedef 13]
anim = 10
sprpriority = 0
velset = 0,0
ctrl =0

[State 13, 1]
type = ChangeAnim
trigger1 = P2Dist X<0
value = 6

[State 13, 1]
type = Turn
trigger1 = P2Dist X<0

[State 10, 1]
type = VelMul
trigger1 = Anim=10&&time=0
x = .75

[State 13, 1]
type = ChangeAnim
trigger1 = AnimTime=0
trigger2 = time=0&&statetype=C
value = 11

[State 13, 1]
type = StateTypeSet
trigger1 = time=0
statetype=C
physics = C

[State 13, 1]
type = ChangeState
trigger1 = roundstate!=2
value = 11
ctrl = 1

[State 13, 1]
type = ChangeState
trigger1 = p2statetype=A && enemynear,time>12 && enemynear,hitfall=0 && !((enemynear,Pos Y=[-60,-47]) && (P2bodydist X=[-20,20+(enemynear,Vel X>0)*20]))
value = 0
ctrl = 1
;----------------------------------------------------------------------

;-----
;歩き（前）（CPU）
[Statedef 21]
type    = S
physics = N
sprpriority = 0
ctrl = 0

[State 20, 1]
type = VelSet
trigger1 = time>=2
x = ifelse((var(49)=[3,5]),2.875,const(velocity.walk.fwd.x))

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20
value = 20

[State 20, 4]
type = changestate
trigger1 = P2dist x <= 0
trigger2 = P2BodyDist X>40 && time>=8
trigger2 = (((P2BodyDist X =[70,80])&&random<500) || (random<200 && P2BodyDist X =[80,120]) || (random<160 && (P2BodyDist X =[120,160])) || (random<70 && P2BodyDist X >160))
trigger3 = P2BodyDist X>40 && time>=4
trigger3 = (P2bodydist X>120&&(enemy,numproj>0||(enemy,numhelper&&inguarddist))&&random<400)
value = 0
ctrl = 1

[State 20, 4]
type = changestate
trigger1 = P2BodyDist X>40 && time>=4
trigger1 = fvar(35)
value = 13

;----------------------------------------------------------------------

;-----
;歩き（後）（CPU）
[Statedef 22]
type    = S
physics = N
sprpriority = 0
ctrl = 0

[State 20, 1]
type = VelSet
trigger1 = time>=2
x = ifelse((var(49)=[3,5]),1.5,const(velocity.walk.back.x))

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21
value = 21

[State 20, 4]
type = changestate
trigger1 = P2dist x <= 0
trigger2 = time>=8 && random<=250
value = 0
ctrl = 1

;_/_/_/_/_/_/
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0+(fvar(27)>0) && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 0+(fvar(27)>0)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
;歩き(Walk)
[Statedef 20]
type    = S
physics = S
sprpriority = 0
ctrl = 1

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd" && time>=2
x = ifelse((var(49)=[3,5]),2.875,const(velocity.walk.fwd.x))

[State 20, 2]
type = VelSet
trigger1 = command = "holdback" && time>=2
x = ifelse((var(49)=[3,5]),-1.5,const(velocity.walk.back.x))

[State 20, 3]
type = ChangeAnim
triggerall = command = "holdfwd"
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
triggerall = command = "holdback"
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21

