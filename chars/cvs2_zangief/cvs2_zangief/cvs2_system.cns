;~~~~コモンステート
;---------------------------------------------------------------------------
; GUARD (start)
[Statedef 120]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged

[State 120, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 120 + (statetype = C) + (statetype = A)*2

[State 120, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 120, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 120, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&!fvar(38)
trigger2 = statetype = C && ((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
statetype = S
physics = S

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = fvar(38)
value = 0

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = time>=(16+(random%5))&&fvar(38)
value = 1

[State 120, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 130 + (statetype = C) + (statetype = A)*2

[State 120, Stop Guarding]
type = ChangeState
trigger1 = command != "holdback" && (statetype!=A ||(statetype=A && P2Dist X>=0))&&!fvar(38)
trigger2 = !inguarddist
trigger3 = command != "holdfwd" && P2Dist X<0 && Statetype=A&&!fvar(38)
value = 140

;---------------------------------------------------------------------------
; STAND GUARD (guarding)
[Statedef 130]
type    = S
physics = S

[State 130, 1]
type = ChangeAnim
trigger1 = Anim != 130
value = 130

[State 130, Hi to Lo]
type = ChangeState
trigger1 = command = "holddown" && !fvar(38)
trigger2 = time&&P2statetype!=A&&!(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))&&fvar(38)
value = 131

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = fvar(38)
value = 0

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = time>=(16+(random%5))&&fvar(38)
value = 1

[State 131, Stop Guarding]
type = ChangeState
trigger1 = command != "holdback"&&!fvar(38)
trigger2 = !inguarddist
value = 140

;---------------------------------------------------------------------------
; CROUCH GUARD (guarding)
[Statedef 131]
type    = C
physics = C

[State 131, 1]
type = ChangeAnim
trigger1 = Anim != 131
value = 131

[State 131, Lo to Hi]
type = ChangeState
trigger1 = command != "holddown" && !fvar(38)
trigger2 = time&&((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
value = 130

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = fvar(38)
value = 0

[State 131, Lo to Hi]
type = CtrlSet
trigger1 = time>=(16+(random%5))&&fvar(38)
value = 1

[State 131, Stop Guarding]
type = ChangeState
trigger1 = command != "holdback"&&!fvar(38)
trigger2 = !inguarddist
value = 140

;---------------------------------------------------------------------------
; AIR GUARD (guarding)
[Statedef 132]
type    = A
physics = N

[State 132, 1]
type = ChangeAnim
trigger1 = Anim != 132
value = 132

[State 132, 2]
type = VelAdd
trigger1 = 1
y = Const(movement.yaccel)

[State 132, 3]
type = VarSet
trigger1 = 1
sysvar(0) = (pos y >= 0) && (vel y > 0)

[State 132, 4]
type = VelSet
trigger1 = sysvar(0)
y = 0

[State 132, 5]
type = PosSet
trigger1 = sysvar(0)
y = 0

[State 132, 6]
type = ChangeState
trigger1 = sysvar(0)
trigger1 = command = "holdback"
trigger1 = inguarddist
value = 130

[State 132, 7]
type = ChangeState
trigger1 = sysvar(0)
value = 52

[State 132, Stop Guarding]
type = ChangeState
trigger1 = command != "holdback" && P2Dist X>=0
trigger2 = !inguarddist
trigger3 = command != "holdfwd" && P2Dist X<0 && Statetype=A
value = 140

;---------------------------------------------------------------------------
; GUARD (end)
[Statedef 140]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged
ctrl = 1

[State 140, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 140 + (statetype = C) + (statetype = A)*2

[State 140, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 140, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 140, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&!fvar(38)
trigger2 = statetype = C && ((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
statetype = S
physics = S

;[State 140, 5] ;Implemented within engine
;type = ChangeState
;trigger1 = AnimTime = 0
;value = (statetype = C)*11 + (statetype = A)*51

;---------------------------------------------------------------------------
; SGUARDHIT (shaking)
[Statedef 150]
type    = S
movetype= H
physics = N
velset = 0,0

[State 150, 1]
type = ChangeAnim
trigger1 = 1
value = 150

[State 150, 2]
type = ChangeState
trigger1 = HitShakeOver
value = 151 + 2*((command = "holddown" && command = "holdback" && !fvar(38)&&!var(11))||fvar(38))

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&!fvar(38)
trigger2 = statetype = C && ((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
statetype = S
physics = S

[State 5300,Pause]
type = VarSet
trigger1 = Time>=1 && (prevstateno!=[4100,4120])
trigger2 = time<=0 && var(50)>1
var(11) = 0
ignorehitpause=1
persistent=0

[State 5300,Pause]
type = VarSet
trigger1 = Time>=1 && (prevstateno!=[4100,4120])
var(50) = 0
ignorehitpause=1
persistent=0

[State 5300,Pause]
type = VarAdd
trigger1 = var(50)>0
var(50) = 1
ignorehitpause=1

[State 5300,Pause]
type = Pause
trigger1 = Time=1 && var(11) && !(enemy,numproj=0 && fvar(10)>0)
time = 5+(fvar(10)>0)*9
movetime = 5+(fvar(10)>0)*9
ignorehitpause=1
persistent=0

[State -2,JustDefence]
type = LifeSet
trigger1 = Life<var(38) && var(11)
value = var(38)+7+floor(var(20)/14)*7
ignorehitpause = 1

[State 150, 3]
type = ForceFeedback
trigger1 = time = 0
waveform = square
time = 3
;-----------------------------------------------
; SGUARDHIT2 (knocked back)
[Statedef 151]
type    = S
movetype= H
physics = S
anim = 150

[State 152, 3]
type = ChangeState
trigger1 = time>0 && !var(11) && command = "holddown" && command = "holdback" && !fvar(38)
trigger2 = time>0 && !var(11) && fvar(38) && P2statetype!=A
value = 153

[State 151, 1]
type = HitVelSet
trigger1 = Time = 0 && !var(11) && prevstateno!=153
x = 1

[State 151, 2]
type = VelSet
trigger1 = Time = GetHitVar(slidetime)
trigger2 = HitOver
trigger3 = var(11)
x = 0

[State 151, 3]
type = CtrlSet
trigger1 = Time = GetHitVar(ctrltime)
value = 1

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&!fvar(38)
trigger2 = statetype = C && ((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
statetype = S
physics = S

[State 151, 4]
type = ChangeState
trigger1 = ifelse(var(11),ifelse(fvar(10)>0&&enemy,numproj=0,var(11)<=0,var(11)<=5),HitOver)
value = 140
ctrl = 1

;---------------------------------------------------------------------------
; CGUARDHIT (shaking)
[Statedef 152]
type    = C
movetype= H
physics = N
velset = 0,0

[State 152, 1]
type = ChangeAnim
trigger1 = 1
value = 151

[State 152, 3]
type = ChangeState
trigger1 = HitShakeOver
value = 153 - 2*((command = "holdback" && command!="holddown" && var(11) && !fvar(38)))

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"&&!fvar(38)
trigger2 = statetype = S && fvar(33) && !((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && fvar(38)
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"&&!fvar(38)
trigger2 = statetype = C && ((P2statetype=A && (enemynear,vel Y>-1||enemynear,pos Y<-70))||(P2statetype=A&&enemynear,time>ifelse(fvar(33),15,18))) && random%7<5 && fvar(38)
statetype = S
physics = S

[State 5300,Pause]
type = VarSet
trigger1 = Time>=1 && (prevstateno!=[4100,4120])
trigger2 = time<=0 && var(50)>1
var(11) = 0
ignorehitpause=1
persistent=0

[State 5300,Pause]
type = VarSet
trigger1 = Time>=1 && (prevstateno!=[4100,4120])
var(50) = 0
ignorehitpause=1
persistent=0

[State 5300,Pause]
type = VarAdd
trigger1 = var(50)>0
var(50) = 1
ignorehitpause=1

[State 5300,Pause]
